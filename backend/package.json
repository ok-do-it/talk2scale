		"pg": "^8.20.0",
		"pino": "^10.3.1",
		"pino-http": "^11.0.0",
		"pino-pretty": "^13.1.3",
		"tsx": "^4.21.0",
		"wavefile": "^11.0.0"
	},
	"devDependencies": {
		"@babel/standalone": "^7.28.5",
		"@biomejs/biome": "^2.4.13",
