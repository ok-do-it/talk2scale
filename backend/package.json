{
	"type": "module",
	"name": "talk2scale",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"scripts": {
		"predev": "lsof -ti :8888 | xargs kill -9 2>/dev/null || true",
		"dev": "tsx watch src/index.ts",
		"start": "tsx src/index.ts",
		"typecheck": "tsc --noEmit",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"clean-reseed": "tsx src/scripts/db/clean-reseed.ts",
		"dedupe-whole-foods": "tsx src/scripts/db/dedupe-whole-foods.ts",
		"download-usda": "tsx src/scripts/download-usda-datasets.ts",
		"clean-db": "tsx src/scripts/db/clean-db.ts",
		"generate-types": "tsx src/scripts/db/generate-db-types.ts",
		"query": "tsx src/scripts/db/query.ts",
		"insert-test-meals": "tsx src/scripts/db/insert-test-meals.ts",
		"embed-food-names": "tsx src/scripts/db/embed-food-names.ts",
		"int-test:voice": "tsx src/scripts/int-test/voice.ts",
		"int-test:search": "tsx src/scripts/int-test/search.ts",
		"int-test": "npm run int-test:voice && npm run int-test:search",
		"copy-vendor-js": "tsx src/scripts/copy-vendor-js.ts",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"author": "",
	"license": "ISC",
