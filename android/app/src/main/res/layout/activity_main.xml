<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Main scale screen (behind the overlay) -->
    <LinearLayout
        android:id="@+id/scaleScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <LinearLayout
                android:id="@+id/mockToolbarGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_mock_toolbar_group"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp">

                <CheckBox
                    android:id="@+id/checkMockTop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="2dp"
                    android:text="Mock" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btnConnectTop"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/stat_sys_data_bluetooth"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Connect to scale"
                android:layout_marginEnd="8dp" />

            <ImageButton
                android:id="@+id/btnCalibrateTop"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_manage"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Calibrate scale" />
        </LinearLayout>

        <!-- Weight display -->
        <TextView
            android:id="@+id/weightDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="16dp"
            android:text="- g"
            android:textColor="@color/weightUnstable"
            android:textSize="48sp"
            android:textStyle="bold" />

        <!-- Tare button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/btnTare"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TARE" />
        </LinearLayout>

        <!-- Food name input with inline actions -->
        <FrameLayout
            android:id="@+id/foodInputContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:paddingHorizontal="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:minHeight="48dp">

                <ImageView
                    android:id="@+id/iconFoodSearch"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="Search food"
                    android:src="@android:drawable/ic_menu_search" />

                <EditText
                    android:id="@+id/editFoodName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Food name"
                    android:inputType="text"
                    android:minHeight="48dp" />

                <ImageButton
                    android:id="@+id/btnClearFood"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Clear food name"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:visibility="gone" />

                <ImageButton
                    android:id="@+id/btnApplyInline"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="2dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Apply food entry"
                    android:padding="8dp"
                    android:src="@drawable/ic_check"
                    android:visibility="gone"
                    app:tint="@android:color/holo_green_dark" />
            </LinearLayout>

            <TextView
                android:id="@+id/textListeningOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#B3000000"
                android:gravity="center"
                android:text="Listening..."
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Full-width MIC button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:icon="@drawable/ic_mic"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            android:text="Voice Input"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="8dp" />

        <!-- Log table header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp"
            android:background="?attr/colorSurfaceVariant">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="3"
                android:text="Food"
                android:textStyle="bold"
                android:textSize="14sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Weight"
                android:textStyle="bold"
                android:textSize="14sp"
                android:gravity="end" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cal"
                android:textStyle="bold"
                android:textSize="14sp"
                android:gravity="end" />
        </LinearLayout>

        <!-- Log RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/logRecycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

    <!-- Calibration overlay (covers entire screen when visible) -->
    <FrameLayout
        android:id="@+id/calibrationOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?android:attr/colorBackground"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btnCloseCalibration"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close calibration" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Calibrate Scale"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Remove everything from the scale and press Set Zero."
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnSetZero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SET ZERO"
                android:layout_marginBottom="32dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2. Place a known weight on the scale, enter it in grams below, and press Set Calibration Weight."
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/editCalibGrams"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Weight in grams"
                android:inputType="number"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnSetCalibWeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SET CALIBRATION WEIGHT" />
        </LinearLayout>
    </FrameLayout>

    <!-- Connection overlay -->
    <include layout="@layout/view_connection_overlay" />

</FrameLayout>
