<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/connectionOverlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:clickable="true"
    android:focusable="true">

    <ImageButton
        android:id="@+id/connectionBtnClose"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/cd_close_connection_overlay"
        android:padding="12dp"
        android:src="@drawable/ic_back"
        android:tint="?android:attr/textColorPrimary" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginBottom="24dp"
            android:importantForAccessibility="no"
            android:src="@android:drawable/stat_sys_data_bluetooth" />

        <TextView
            android:id="@+id/connectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/status_searching"
            android:textSize="18sp" />

        <ProgressBar
            android:id="@+id/connectionSpinner"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/connectionBtnConnect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_connect" />

        <Button
            android:id="@+id/connectionBtnDisconnect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_disconnect" />

        <Button
            android:id="@+id/connectionBtnForgetAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_forget_all" />

    </LinearLayout>
</FrameLayout>
